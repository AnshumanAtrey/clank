---

<section class="subs">
  <div class="container">
    <h2>every subcommand. <span class="text-dim">click to see it run.</span></h2>

    <div class="grid">
      {subs.map((sub, i) => (
        <button
          class={`card ${i === 0 ? 'active' : ''}`}
          data-sub={sub.id}
          type="button"
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          <div class="card-head">
            <code class="name">{sub.name}</code>
            <span class={`status ${sub.status.cls}`}>{sub.status.text}</span>
          </div>
          <p class="desc">{sub.desc}</p>
        </button>
      ))}
    </div>

    <div class="demos">
      {subs.map((sub, i) => (
        <div class={`demo ${i === 0 ? 'active' : ''}`} data-demo={sub.id}>
          <div class="terminal">
            <div class="terminal-header">
              <span class="terminal-dot"></span>
              <span class="terminal-dot"></span>
              <span class="terminal-dot"></span>
              <span class="terminal-title">~/clank</span>
            </div>
            <pre class="terminal-body" set:html={colorize(sub.demo)} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    gap: 0.6rem;
    margin: var(--space-md) 0 var(--space-md);
    grid-template-columns: 1fr;
  }
  @media (min-width: 600px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.75rem 0.875rem;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-mono);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .card:hover {
    border-color: var(--fg-dim);
  }
  .card.active {
    border-color: var(--accent);
    background: var(--bg-card);
  }
  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }
  .name {
    background: transparent;
    padding: 0;
    color: var(--fg-bright);
    font-weight: 600;
    font-size: 0.875rem;
  }
  .status {
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }
  .st-ok {
    color: var(--accent);
    border-color: var(--accent);
  }
  .st-warn {
    color: var(--accent-warn);
    border-color: var(--accent-warn);
  }
  .st-broken {
    color: var(--accent-danger);
    border-color: var(--accent-danger);
  }
  .desc {
    color: var(--fg);
    font-size: 0.82rem;
    margin: 0;
    line-height: 1.4;
  }

  .demos {
    margin-top: 0.5rem;
  }
  .demo {
    display: none;
  }
  .demo.active {
    display: block;
    animation: fadeIn 0.18s ease-out;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .terminal-body {
    margin: 0;
    font-size: 0.85rem;
    min-height: 16rem;
  }
  @media (max-width: 600px) {
    .terminal-body {
      font-size: 0.74rem;
    }
  }
</style>

<script>
  function init() {
    const cards = document.querySelectorAll<HTMLButtonElement>('.card[data-sub]');
    const demos = document.querySelectorAll<HTMLDivElement>('[data-demo]');

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const target = card.dataset.sub;
        if (!target) return;

        cards.forEach((c) => {
          const isActive = c === card;
          c.classList.toggle('active', isActive);
          c.setAttribute('aria-pressed', String(isActive));
        });

        demos.forEach((d) => {
          d.classList.toggle('active', d.dataset.demo === target);
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
