// Build-time colorize — same marker syntax as Hero. All demos render at build
// time with span classes baked in. Zero runtime templating cost.
function colorize(text: string): string {
  return text
    .replace(/§a:([^§]+)§/g, '<span class="accent">$1</span>')
    .replace(/§w:([^§]+)§/g, '<span class="warn">$1</span>')
    .replace(/§d:([^§]+)§/g, '<span class="danger">$1</span>')
    .replace(/§m:([^§]+)§/g, '<span class="dim">$1</span>')
    .replace(/§b:([^§]+)§/g, '<span class="bright">$1</span>');
}

