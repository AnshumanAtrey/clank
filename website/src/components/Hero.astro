---
const installCmd = 'brew install AnshumanAtrey/tap/clank';
---

<section class="hero">
  <figure class="hero-frame">
    <img
      src="/clank-snail.jpg"
      alt="Clank — a snail-shaped intercom held in a hand, resting on a wooden barrel"
      width="3980"
      height="1030"
      fetchpriority="high"
      decoding="async"
    />
  </figure>

  <div class="container hero-card-wrap">
    <div class="hero-card">
      <span class="eyebrow">v0.1.0 · MIT · open source</span>
      <h1>
        phone-number OSINT.<br />
        <span class="serif-italic">one binary.</span> ten subcommands.
      </h1>
      <p class="hero-lead">
        Open-source CLI for phone-number reconnaissance. No signup. No API gate.
        What PhoneInfoga should have been in 2026.
      </p>

      <div class="install-line">
        <code class="install-cmd">{installCmd}</code>
        <button
          class="copy-btn"
          data-cmd={installCmd}
          aria-label="Copy install command"
          type="button">copy</button>
      </div>

      <div class="hero-ctas">
        <a class="btn btn-primary" href="#install">install →</a>
        <a class="btn" href="https://github.com/AnshumanAtrey/clank">view on github</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 0 0 var(--space-lg);
  }

  /* Image frame — full bleed, capped at sensible max */
  .hero-frame {
    margin: 0;
    width: 100%;
    max-width: 1400px;
    margin-inline: auto;
    padding: 0 var(--space-md);
    box-sizing: border-box;
  }
  .hero-frame img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    box-shadow: var(--shadow-lift);
    /* tiny wood-frame ring */
    outline: 1px solid var(--oak-dark);
    outline-offset: 0;
  }

  /* Cream card lifts off the page below the image */
  .hero-card-wrap {
    margin-top: -2rem;
    position: relative;
    z-index: 2;
  }
  @media (min-width: 768px) {
    .hero-card-wrap {
      margin-top: -3.5rem;
    }
  }

  .hero-card {
    background: var(--paper-soft);
    background-image: var(--grain);
    background-size: 240px 240px;
    border-radius: 4px;
    padding: 1.75rem 1.75rem 1.5rem;
    max-width: 720px;
    margin: 0 auto;
    box-shadow: var(--shadow-lift);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
  @media (min-width: 768px) {
    .hero-card {
      padding: 2.25rem 2.5rem 2rem;
    }
  }

  .hero-card .eyebrow {
    margin-bottom: 0.85rem;
  }

  .hero-card h1 {
    margin-bottom: 0.85rem;
    color: var(--ink);
  }

  .serif-italic {
    font-style: italic;
    font-variation-settings: 'SOFT' 100, 'opsz' 144;
    color: var(--brick);
    font-weight: 600;
  }

  .hero-lead {
    color: var(--ink-dim);
    font-size: 1.05rem;
    margin-bottom: 1.25rem;
    max-width: 36rem;
    line-height: 1.55;
  }

  .install-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--walnut);
    color: var(--cream);
    padding: 0.65rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-press);
  }
  .install-cmd {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--cream);
    background: transparent;
    border: none;
    padding: 0;
    flex: 1;
    overflow-x: auto;
    white-space: nowrap;
  }
  .copy-btn {
    background: transparent;
    border: 1px solid var(--cream-dim);
    color: var(--cream-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .copy-btn:hover {
    color: var(--cream);
    border-color: var(--cream);
  }
  .copy-btn.copied {
    color: #95e6cb;
    border-color: #95e6cb;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
</style>

<script>
  function initCopy() {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn[data-cmd]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const cmd = btn.dataset.cmd;
        if (!cmd) return;
        try {
          await navigator.clipboard.writeText(cmd);
          btn.textContent = 'copied ✓';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'copy';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = 'select';
          setTimeout(() => {
            btn.textContent = 'copy';
          }, 2000);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopy);
  } else {
    initCopy();
  }
</script>
