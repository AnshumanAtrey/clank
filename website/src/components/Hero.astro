---
// Server-side colorize — expands §a:text§ markers to span classes at build
// time. Zero runtime cost; HTML ships pre-colored.
function colorize(text: string): string {
  return text
    .replace(/§a:([^§]+)§/g, '<span class="accent">$1</span>')
    .replace(/§w:([^§]+)§/g, '<span class="warn">$1</span>')
    .replace(/§d:([^§]+)§/g, '<span class="danger">$1</span>')
    .replace(/§m:([^§]+)§/g, '<span class="dim">$1</span>')
    .replace(/§b:([^§]+)§/g, '<span class="bright">$1</span>');
}

const heroDemo = `§a:$ §§b:clank deep§ +14155552671

§b:Deep lookup§ — +14155552671

§m:1.§ §b:Local§ — libphonenumber + spam check
  +14155552671  §a:FIXED_OR_MOBILE§  §a:US§  San Francisco, CA

§m:2.§ §b:Free APIs§
  §m:numverify§    §w:skipped§ — NUMVERIFY_KEY not set
  §m:veriphone§    §a:valid§ · MOBILE · AT&T · United States
  §m:ipqs§         §a:valid§ · MOBILE · AT&T · §m:fraud=§§a:12§

§m:3.§ §b:Telegram§
  §a:registered§ · §a:@jane_d§ · Jane Doe

§m:4.§ §b:WhatsApp§
  §a:registered§ · jid=14155552671§m:@s.whatsapp.net§

§m:5.§ §b:Account presence§
  §m:instagram§  §a:registered§
  §m:snapchat§   §w:?§ — method broken (Snapchat redesigned web auth ~2024)
  §m:amazon§     §w:?§ rate-limited / inconclusive

§m:6.§ §b:SEC EDGAR full-text§
  §m:0§ hits

§m:Took 6.2s§`;
---

