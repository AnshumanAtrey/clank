---
const faqs = [
  {
    q: 'Why open-source?',
    a: "Because phone OSINT shouldn't require a $99/mo Truecaller-Pro subscription. The data is public. The tool should be too.",
  },
  {
    q: 'Is this legal?',
    a: 'Depends on your jurisdiction. clank queries public data sources via documented endpoints. Same as any web search. Misuse (stalking, harassment) is illegal regardless of tool. Read the README\'s Disclaimer.',
  },
  {
    q: 'Will you add Truecaller?',
    a: 'Yes — top of the v0.2.0 roadmap. See the GitHub issue tracker for ETA.',
  },
  {
    q: 'How does it compare to PhoneInfoga?',
    a: 'clank: faster (Go binary, no Python deps), more sources (Telegram/WhatsApp/EDGAR), honest about brokenness. PhoneInfoga: web UI, more provider integrations, more battle-tested. Use both.',
  },
  {
    q: 'Can I contribute?',
    a: 'Yes. Issues + PRs welcome at github.com/AnshumanAtrey/clank. Roadmap is public in path-1/01-launch-strategy.md.',
  },
  {
    q: 'Does it phone home?',
    a: 'No. Zero telemetry. Zero analytics. Zero outbound calls except to the OSINT data sources you explicitly invoke. Audit log lives at ~/.clank/history.jsonl on your machine, never sent anywhere. Set CLANK_NO_AUDIT=1 to disable even that.',
  },
];
---

<section class="faq">
  <div class="container">
    <span class="eyebrow">questions from the crew</span>
    <h2>faq</h2>
    <div class="list">
      {faqs.map((f) => (
        <details>
          <summary>
            <span class="q-mark">Q.</span>
            <span class="q-text">{f.q}</span>
            <span class="open-mark" aria-hidden="true">+</span>
          </summary>
          <div class="answer">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq h2 {
    margin-bottom: var(--space-md);
    margin-top: 0.4rem;
  }
  .list {
    display: grid;
    gap: 0.6rem;
  }
  details {
    background: var(--paper-soft);
    background-image: var(--grain);
    background-size: 240px 240px;
    border-left: 3px solid var(--cord);
    border-radius: 2px;
    padding: 1rem 1.2rem;
    box-shadow: var(--shadow-rest);
    transition: box-shadow 0.2s ease;
  }
  details[open] {
    box-shadow: var(--shadow-lift);
    border-left-color: var(--snail);
  }
  summary {
    cursor: pointer;
    color: var(--ink);
    list-style: none;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  .q-mark {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 600;
    color: var(--snail);
    flex-shrink: 0;
    font-size: 1.05rem;
  }
  .q-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    flex: 1;
    color: var(--ink);
  }
  .open-mark {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.2s ease;
    line-height: 1;
  }
  details[open] .open-mark {
    transform: rotate(45deg);
    color: var(--snail);
  }
  .answer {
    color: var(--ink-dim);
    margin-top: 0.7rem;
    padding-left: 1.6rem;
    font-size: 0.95rem;
    line-height: 1.65;
  }
</style>
