---
const broken = [
  {
    title: 'Snapchat phone lookup',
    desc: "Their CSRF moved JS-side in 2024. Method broken. Documented inline. Will fix in v0.2.0.",
  },
  {
    title: 'Messenger ban risk at scale',
    desc: 'WhatsApp/Telegram lookups can ban your session above ~50/min. Use a burner account or stick to small scans.',
  },
  {
    title: 'Carrier portability',
    desc: "libphonenumber returns the originally-allocated carrier, not current. After number portability the answer may be wrong. Honest about it.",
  },
  {
    title: 'No pastebin search',
    desc: 'psbdmp.cc went dark in 2024. Hunting for a replacement.',
  },
];

const works = [
  'libphonenumber lookup (instant, no key)',
  'MCC/MNC carrier list (embedded)',
  'Spam blacklist (embedded)',
  'IMEI decoder + 254k-device TAC DB (embedded)',
  'Google-dork URL generator',
  'SEC EDGAR full-text search (no key)',
  'Telegram + WhatsApp + Instagram (with one-time setup)',
];
---

<section class="honest">
  <div class="container">
    <h2 class="text-warn">what's broken.</h2>
    <p class="lead">
      Most "OSINT toolkit" landing pages oversell.<br />
      This one doesn't. Here's what doesn't work yet.
    </p>

    <ul class="broken-list">
      {broken.map((b) => (
        <li>
          <strong class="text-warn">×</strong>
          <div>
            <div class="b-title">{b.title}</div>
            <div class="b-desc">{b.desc}</div>
          </div>
        </li>
      ))}
    </ul>

    <h3 class="works-title text-accent">what works out of the box.</h3>
    <ul class="works-list">
      {works.map((w) => (
        <li>
          <span class="text-accent">✓</span> {w}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .lead {
    color: var(--fg-dim);
    margin: var(--space-sm) 0 var(--space-md);
  }
  .broken-list {
    list-style: none;
    margin: 0 0 var(--space-md);
    padding: 0;
    display: grid;
    gap: 0.875rem;
  }
  .broken-list li {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.875rem 1rem;
  }
  .broken-list strong {
    font-size: 1.1rem;
    line-height: 1;
    flex-shrink: 0;
    width: 1.25rem;
  }
  .b-title {
    font-weight: 600;
    color: var(--fg-bright);
    margin-bottom: 0.2rem;
  }
  .b-desc {
    color: var(--fg);
    font-size: 0.9rem;
  }
  .works-title {
    margin: var(--space-md) 0 var(--space-sm);
    font-size: 1rem;
  }
  .works-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .works-list li {
    color: var(--fg);
    font-size: 0.9rem;
  }
</style>
