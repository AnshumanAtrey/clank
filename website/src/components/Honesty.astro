---
const broken = [
  {
    date: '2024 — discovered',
    title: 'Snapchat phone lookup',
    desc: "Their CSRF moved JS-side in 2024. Method broken. Documented inline. Will fix in v0.2.0.",
    tag: 'broken',
  },
  {
    date: 'observed at scale',
    title: 'Messenger ban risk',
    desc: 'WhatsApp/Telegram lookups can ban your session above ~50/min. Use a burner account or stick to small scans.',
    tag: 'caution',
  },
  {
    date: 'inherent to the data',
    title: 'Carrier portability',
    desc: "libphonenumber returns the originally-allocated carrier, not current. After number portability the answer may be wrong. Honest about it.",
    tag: 'limitation',
  },
  {
    date: '2024 — site went dark',
    title: 'No pastebin search',
    desc: 'psbdmp.cc went dark in 2024. Hunting for a replacement.',
    tag: 'gone',
  },
];

const works = [
  'libphonenumber lookup (instant, no key)',
  'MCC/MNC carrier list (embedded)',
  'Spam blacklist (embedded)',
  'IMEI decoder + 254k-device TAC DB (embedded)',
  'Google-dork URL generator',
  'SEC EDGAR full-text search (no key)',
  'Telegram + WhatsApp + Instagram (with one-time setup)',
];
---

<section class="honest">
  <div class="container">
    <span class="eyebrow">captain's log</span>
    <h2>what's broken. <span class="serif-italic">no spin.</span></h2>
    <p class="lead">
      Most "OSINT toolkit" landing pages oversell. This one doesn't.
      Below: every limitation logged before you find it yourself.
    </p>

    <ul class="log">
      {broken.map((b) => (
        <li class="log-entry">
          <div class="log-date">{b.date}</div>
          <div class="log-card">
            <div class="log-head">
              <h3 class="log-title">{b.title}</h3>
              <span class="stamp stamp-broken">{b.tag}</span>
            </div>
            <p class="log-desc">{b.desc}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="works-block">
      <span class="eyebrow">inventory check</span>
      <h3>what works out of the box.</h3>
      <ul class="works-list">
        {works.map((w) => (
          <li>
            <span class="check">✓</span>
            <span>{w}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .honest h2 .serif-italic {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-mute);
    font-weight: 400;
  }
  .lead {
    color: var(--ink-dim);
    margin: 0.6rem 0 var(--space-md);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    max-width: 36rem;
  }

  .log {
    list-style: none;
    margin: 0 0 var(--space-md);
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .log-entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  @media (min-width: 700px) {
    .log-entry {
      grid-template-columns: 12rem 1fr;
      gap: 1.25rem;
    }
  }
  .log-date {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-mute);
    font-size: 0.92rem;
    padding-top: 0.4rem;
  }
  .log-card {
    background: var(--paper-soft);
    background-image: var(--grain);
    background-size: 240px 240px;
    border-left: 3px solid var(--brick);
    padding: 1rem 1.25rem;
    border-radius: 2px;
    box-shadow: var(--shadow-rest);
  }
  .log-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .log-title {
    font-size: 1.1rem;
    color: var(--ink);
    margin: 0;
  }
  .log-desc {
    color: var(--ink-dim);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.55;
  }

  .works-block {
    margin-top: var(--space-lg);
  }
  .works-block h3 {
    margin: 0.5rem 0 var(--space-sm);
    font-size: 1.25rem;
  }
  .works-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .works-list li {
    color: var(--ink-dim);
    font-size: 0.95rem;
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
  }
  .check {
    color: var(--stamp-green);
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
