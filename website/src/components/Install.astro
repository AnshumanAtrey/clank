---
const tabs = [
  {
    id: 'brew',
    label: 'Homebrew',
    note: 'tap setup pending — see issue #3',
    cmd: 'brew install AnshumanAtrey/tap/clank',
  },
  {
    id: 'binary',
    label: 'Pre-built binary',
    note: 'macOS / Linux / Windows from GitHub Releases',
    cmd: 'curl -L https://github.com/AnshumanAtrey/clank/releases/latest/download/clank_$(uname -s)_$(uname -m).tar.gz | tar xz',
  },
  {
    id: 'go',
    label: 'go install',
    note: 'requires Go 1.25+',
    cmd: 'go install github.com/AnshumanAtrey/clank@latest',
  },
];
---

<section id="install" class="install">
  <div class="container">
    <h2>three ways to install. <span class="serif-italic">pick yours.</span></h2>

    <div class="folder">
      <div class="tabs" role="tablist">
        {tabs.map((tab, i) => (
          <button
            class={`tab ${i === 0 ? 'active' : ''}`}
            data-tab={tab.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            type="button"
          >
            {tab.label}
          </button>
        ))}
      </div>

      <div class="panels">
        {tabs.map((tab, i) => (
          <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id} role="tabpanel">
            <div class="note">{tab.note}</div>
            <div class="terminal">
              <div class="terminal-header">
                <span class="terminal-dot"></span>
                <span class="terminal-dot"></span>
                <span class="terminal-dot"></span>
                <span class="terminal-title">install.sh</span>
              </div>
              <div class="terminal-body cmd-row">
                <code class="cmd-text">{tab.cmd}</code>
                <button class="copy-btn" data-cmd={tab.cmd} type="button" aria-label="Copy install command">
                  copy
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="verify">
      <div class="verify-label">After install, verify:</div>
      <div class="terminal">
        <div class="terminal-body">
<span class="prompt">$ </span><span class="bright">clank --version</span>
<span class="bright">clank v0.1.0</span>
<span class="dim">by Anshuman Atrey · https://atrey.dev · build@atrey.dev</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .install h2 .serif-italic {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-mute);
    font-weight: 400;
  }

  .folder {
    margin-top: var(--space-md);
  }

  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    padding-left: 0.4rem;
  }
  .tab {
    background: var(--paper-soft);
    background-image: var(--grain);
    background-size: 240px 240px;
    border: 1px solid var(--oak-dark);
    border-bottom: none;
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.55rem 1rem 0.7rem;
    border-radius: 6px 6px 0 0;
    cursor: pointer;
    transition: all 0.15s ease;
    margin-bottom: -1px;
    position: relative;
    z-index: 1;
  }
  .tab:hover {
    color: var(--ink);
    background: var(--paper);
  }
  .tab.active {
    color: var(--ink);
    background: var(--paper-soft);
    background-image: var(--grain);
    background-size: 240px 240px;
    z-index: 3;
    font-weight: 500;
    border-bottom: 1px solid var(--paper-soft);
  }

  .panel {
    display: none;
  }
  .panel.active {
    display: block;
    animation: pageSlide 0.2s ease-out;
  }
  @keyframes pageSlide {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Folder body — paper card under tabs */
  .panels {
    background: var(--paper-soft);
    background-image: var(--grain);
    background-size: 240px 240px;
    border: 1px solid var(--oak-dark);
    border-radius: 0 6px 6px 6px;
    padding: 1.25rem;
    box-shadow: var(--shadow-rest);
    position: relative;
    z-index: 2;
  }

  .note {
    color: var(--ink-dim);
    font-size: 0.82rem;
    margin-bottom: 0.65rem;
    font-style: italic;
    font-family: var(--font-serif);
  }
  .cmd-row {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    min-height: 0;
  }
  .cmd-text {
    background: transparent;
    padding: 0;
    border: none;
    color: var(--cream);
    font-size: 0.82rem;
    flex: 1;
    overflow-x: auto;
    white-space: nowrap;
    font-family: var(--font-mono);
  }
  .copy-btn {
    background: transparent;
    border: 1px solid var(--cream-dim);
    color: var(--cream-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .copy-btn:hover {
    color: var(--cream);
    border-color: var(--cream);
  }
  .copy-btn.copied {
    color: #95e6cb;
    border-color: #95e6cb;
  }

  .verify {
    margin-top: var(--space-md);
  }
  .verify-label {
    color: var(--ink-dim);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    font-style: italic;
    font-family: var(--font-serif);
  }
</style>

<script>
  function init() {
    document.querySelectorAll<HTMLButtonElement>('.tab[data-tab]').forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        if (!target) return;

        document.querySelectorAll<HTMLButtonElement>('.tab[data-tab]').forEach((t) => {
          const isActive = t === tab;
          t.classList.toggle('active', isActive);
          t.setAttribute('aria-selected', String(isActive));
        });

        document.querySelectorAll<HTMLDivElement>('[data-panel]').forEach((p) => {
          p.classList.toggle('active', p.dataset.panel === target);
        });
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.copy-btn[data-cmd]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const cmd = btn.dataset.cmd;
        if (!cmd) return;
        try {
          await navigator.clipboard.writeText(cmd);
          btn.textContent = 'copied ✓';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'copy';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = 'select';
          setTimeout(() => {
            btn.textContent = 'copy';
          }, 2000);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
